{
  "name": "flowdesk",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "npm run start --workspace=@flowdesk/web",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:push": "npm run db:push --workspace=@flowdesk/db",
    "db:generate": "npm run generate --workspace=@flowdesk/db",
    "db:studio": "npm run studio --workspace=@flowdesk/db"
  },
  "dependencies": {
    "turbo": "^2.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.0"
}