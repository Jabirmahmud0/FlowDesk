# ─── Database ─────────────────────────────────────────
# PostgreSQL connection string (e.g., postgresql://user:password@host:5432/flowdesk)
DATABASE_URL=postgresql://username:password@localhost:5432/flowdesk

# ─── NextAuth ─────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
# Production URL (e.g., https://flowdesk.com)
NEXTAUTH_URL=http://localhost:3000

# ─── OAuth (Google) ───────────────────────────────────
# Optional - enable Google OAuth login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth (GitHub) ───────────────────────────────────
# Optional - enable GitHub OAuth login
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Stripe ───────────────────────────────────────────
# Required for subscription billing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# Stripe CLI webhook secret for local development
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── Redis (Upstash) ─────────────────────────────────
# Required for real-time features, job queues, caching
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# ─── Cloudinary ───────────────────────────────────────
# Required for file uploads (avatars, attachments)
# Get credentials from https://cloudinary.com/users/register/free
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional: Use unsigned upload preset for client-side uploads
# Create preset in Cloudinary dashboard > Settings > Upload > Add upload preset
CLOUDINARY_UPLOAD_PRESET=
# For client-side uploads (optional):
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_preset

# ─── Email (Resend) ───────────────────────────────────
# Required for email notifications, invites
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=FlowDesk <noreply@yourdomain.com>

# ─── App Configuration ────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# WebSocket server URL for real-time features
NEXT_PUBLIC_WS_URL=http://localhost:3020

# ─── Sentry (Error Tracking) ──────────────────────────
# Optional - production error monitoring
SENTRY_DSN=

# ─── Firebase Admin (Optional) ────────────────────────
# For Firebase services integration
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── GraphQL (Apollo) ─────────────────────────────────
# Optional - if using GraphQL API
APOLLO_GRAPHQL_ENDPOINT=/api/graphql
